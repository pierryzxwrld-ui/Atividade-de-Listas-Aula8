#8. Crie um programa que: leia 12 números inteiros e armazene-os em uma lista, exiba os números em ordem crescente, exiba os números em ordem decrescente, informe quantos números são pares e quantos são ímpares.
lista = []
pares = 0
impares = 0

for i in range(12):
    numero = int(input("Digite um número inteiro: "))
    lista.append(numero)

lista.sort()
print("Ordem crescente:", lista)

lista.sort(reverse=True)
print("Ordem decrescente:", lista)

for numero in lista:
    if numero % 2 == 0:
        pares += 1
    else:
        impares += 1

print("Quantidade de números pares:", pares)
print("Quantidade de números ímpares:", impares)
