#4. Desenvolva um programa que: leia 10 números inteiros e os armazene em uma lista, solicite ao usuário um número para remoção, remova todas as ocorrências desse número da lista, exiba a lista atualizada. Caso o número não exista na lista, informe ao usuário.
lista = []

for i in range(10):
    numero = int(input("Digite um número inteiro: "))
    lista.append(numero)

remover = int(input("Digite o número que deseja remover: "))

if remover in lista:
    while remover in lista:
        lista.remove(remover)
    print("Lista atualizada:", lista)
else:
    print("O número não existe na lista.")
