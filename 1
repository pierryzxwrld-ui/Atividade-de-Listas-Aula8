#1. Leia 10 números inteiros e armazene-os em uma lista. Ao final: mostre todos os valores, informe o maior valor, informe o menor valor.
lista = []

for i in range(10):
    numero = int(input("Digite um número inteiro: "))
    lista.append(numero)

print("Valores da lista:")
for numero in lista:
    print(numero)
maior = max(lista)
menor = min(lista)
print("Maior valor:", maior)
print("Menor valor:", menor)
